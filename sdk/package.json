{
  "name": "@stellar-passkey/sdk",
  "version": "0.1.0",
  "description": "Seedless smart wallet SDK for Stellar/Soroban using WebAuthn passkeys",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^9.0.0",
    "@simplewebauthn/types": "^9.0.0",
    "@stellar/stellar-sdk": "^13.0.0",
    "cbor-x": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
